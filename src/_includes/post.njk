<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }} // WORTH.EE</title>
    <link rel="stylesheet" href="/css/dist.css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Space Grotesk', "PingFang SC", sans-serif; background-color: #f7f7f7; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .font-syne { font-family: 'Syne', sans-serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        
        #outerWrap {
            width: 95%; max-width: 850px; height: 90vh;
            border: 1px solid #111; display: flex; flex-direction: row;
            background: white; overflow: hidden;
        }
        @media (max-width: 768px) {
            body { padding: 0; }
            #outerWrap { width: 100%; height: 100vh; border: none; flex-direction: column; }
            #sidebar { display: none; }
        }
        .article-body { font-size: 0.95rem; line-height: 1.6; color: #111; letter-spacing: -0.01em; }
        .article-body p { margin-bottom: 0.8rem; }
        
        .nav-item { display: block; width: 100%; }
    </style>
</head>
<body class="selection:bg-[#111] selection:text-white overflow-hidden">
<div id="outerWrap">
<aside id="sidebar" class="w-[220px] border-r border-[#111] p-6 flex flex-col shrink-0 bg-white">
    <a href="/" class="font-syne text-[10px] font-black tracking-[0.2em] mb-8 text-[#111] no-underline block uppercase">
        WORTH.EE
    </a>
    
    <div class="text-[9px] font-mono text-neutral-400 mb-6 tracking-[0.2em] uppercase border-b border-[#111] pb-2">
        [INDEX_FILE]
    </div>
    
    <div class="flex flex-col gap-4 font-mono">
        {% for post in collections.posts %}
        <a href="{{ post.url }}" class="nav-item text-[10px] leading-tight {% if page.url == post.url %}text-[#111] font-bold{% else %}text-neutral-400 hover:text-[#111]{% endif %} no-underline flex flex-col gap-1">
            <span class="opacity-60">{{ loop.index | idx }}</span>
            <span>{{ post.data.title | truncate(20) }}</span>
        </a>
        {% endfor %}
    </div>
</aside>
    <main class="flex-1 flex flex-col overflow-hidden">
        <header class="flex w-full border-b border-[#111] h-10 items-center justify-between px-5 shrink-0 text-[8px] font-mono text-neutral-400">
            <div>[{{ category or "POST" }}] {{ date | date("yyyy.MM.dd") }}</div>
            <div class="flex items-center gap-4">
                <div id="clock">00:00:00</div>
                <a href="/" class="text-neutral-400 hover:text-[#111] transition-colors no-underline">[← BACK]</a>
            </div>
        </header>
        <div class="flex-1 overflow-y-auto no-scrollbar p-6">
            <div class="w-full">
                <h1 class="font-syne text-3xl font-black tracking-tight leading-[0.9] mb-6 text-[#111]">
                    {{ title }}
                </h1>
                <div class="article-body">
                    {{ content | safe }}
                </div>
                <div class="border-t border-dotted border-neutral-200 mt-10 pt-6 grid grid-cols-2 gap-4 text-[9px] font-mono">
                    <div>
                        {% if prevPost %}
                        <div class="text-neutral-400 mb-1">← PREV</div>
                        <a href="{{ prevPost.url }}" class="text-neutral-600 hover:text-[#111] no-underline text-[10px] font-bold">{{ prevPost.data.title | truncate(30) }}</a>
                        {% endif %}
                    </div>
                    <div class="text-right">
                        {% if nextPost %}
                        <div class="text-neutral-400 mb-1">NEXT →</div>
                        <a href="{{ nextPost.url }}" class="text-neutral-600 hover:text-[#111] no-underline text-[10px] font-bold">{{ nextPost.data.title | truncate(30) }}</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <footer class="h-8 border-t border-[#111] flex items-center px-5 text-[8px] font-mono text-neutral-400 justify-between">
            <div>© 2026 WORTH.EE LIGHT PROTOCOL.</div>
            <a href="/" class="text-[#111] hover:underline no-underline uppercase tracking-widest">[▲ INDEX]</a>
        </footer>
    </main>
</div>
<script>
(function tick(){
    document.getElementById('clock').textContent = new Date().toTimeString().split(' ')[0];
    setTimeout(tick, 1000);
})();
</script>
</body>
</html>
