<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }} // WORTH.EE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet">
    <style>
        .font-syne { font-family: 'Syne', sans-serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* 核心布局：居中悬浮档案框 */
        body { background-color: #f7f7f7; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        #outerWrap {
            width: 90%; max-width: 650px; height: 85vh;
            border: 1px solid #111; display: flex; flex-direction: column;
            background: white; overflow: hidden;
        }

        /* 移动端适配 */
        @media (max-width: 768px) {
            body { padding: 0; }
            #outerWrap { width: 100%; height: 100vh; border: none; }
        }

        /* 内容排版 */
        .article-body { font-size: 0.95rem; line-height: 1.85; color: #111111; font-weight: 400; }
        .article-body p { margin-bottom: 1.5rem; }
        .article-body h2 { font-family: 'Syne', sans-serif; font-size: 1.2rem; margin: 2rem 0 1rem; }
        .article-body a { text-decoration: underline; text-underline-offset: 4px; }
        .article-body a:hover { color: #d00; }
    </style>
</head>
<body class="selection:bg-[#111] selection:text-white overflow-hidden">

<div id="outerWrap">
    <header class="flex w-full border-b border-[#111] h-14 items-center justify-between px-6 shrink-0 bg-white">
        <div class="font-syne text-lg tracking-tighter flex items-center gap-2">
            <a href="/" class="font-black no-underline text-[#111]">WORTH.EE</a>
            <span class="text-[9px] bg-[#111] text-white px-1.5 py-0.5 font-mono">// ARCHIVE</span>
        </div>
        <div class="font-mono text-[10px] tracking-widest text-neutral-400" id="clock">00:00:00</div>
    </header>

    <main class="flex-1 overflow-y-auto no-scrollbar bg-white">
        <div class="max-w-[500px] mx-auto px-6 py-12">
            <div class="text-[9px] font-mono text-neutral-400 tracking-widest mb-8 flex gap-4">
                <span>[{{ category or "00 // METADATA" }}]</span>
                <span>{{ date | date("yyyy.MM.dd") }}</span>
            </div>

            <h1 class="font-syne text-3xl font-black tracking-tighter leading-[1] mb-12 text-[#111]">
                {{ title }}
            </h1>

            <div class="article-body">
                {{ content | safe }}
            </div>

            <nav class="mt-20 pt-8 border-t border-[#111] grid grid-cols-2 gap-8">
                {% if prevPost %}
                <a href="{{ prevPost.url }}" class="block no-underline text-[#111]">
                    <div class="text-[9px] font-mono text-neutral-400 mb-2">← PREV</div>
                    <div class="text-[11px] font-bold hover:underline">{{ prevPost.data.title | truncate(20) }}</div>
                </a>
                {% endif %}
                {% if nextPost %}
                <a href="{{ nextPost.url }}" class="block no-underline text-[#111] text-right">
                    <div class="text-[9px] font-mono text-neutral-400 mb-2">NEXT →</div>
                    <div class="text-[11px] font-bold hover:underline">{{ nextPost.data.title | truncate(20) }}</div>
                </a>
                {% endif %}
            </nav>
        </div>
    </main>

    <footer class="flex w-full border-t border-[#111] h-10 items-center justify-between px-6 text-[9px] font-mono text-neutral-400 bg-white shrink-0">
        <div>© 2026 WORTH.EE</div>
        <a href="/" class="text-[#111] hover:underline no-underline">[▲ INDEX]</a>
    </footer>
</div>

<script>
    function updateClock() {
        document.getElementById('clock').textContent = new Date().toTimeString().split(' ')[0];
    }
    setInterval(updateClock, 1000); updateClock();
</script>
</body>
</html>
