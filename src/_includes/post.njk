<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} // WORTH.EE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --font-main: 'Inter', sans-serif; --font-mono: 'Space Mono', monospace; }
        body { font-family: var(--font-main); background-color: #f7f7f7; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .font-mono { font-family: var(--font-mono); }
        
        #outerWrap { width: 95%; max-width: 850px; height: 90vh; border: 1px solid #111; display: flex; flex-direction: row; background: white; overflow: hidden; }

        /* 移动端深度适配 */
        @media (max-width: 768px) {
            body { padding: 0; display: block; }
            #outerWrap { width: 100%; height: 100%; border: none; flex-direction: column; }
            #sidebar { display: none; }
            .mobile-back { display: flex !important; } /* 强制显示返回按钮 */
        }

        .article-body { font-size: 1rem; line-height: 1.7; color: #111; }
        .article-body p { margin-bottom: 1rem; }
    </style>
</head>
<body>

<div id="outerWrap">
    <aside id="sidebar" class="w-[240px] border-r border-[#111] p-8 flex flex-col shrink-0 bg-white">
        <a href="/" class="text-xl font-bold mb-12 text-[#111] no-underline block tracking-tighter">WORTH.EE</a>
        <div class="text-[10px] font-mono text-neutral-400 mb-8 uppercase border-b border-[#111] pb-3">[INDEX_FILE]</div>
        <div class="flex flex-col gap-6 font-mono">
            {% for post in collections.posts %}
            <a href="{{ post.url }}" class="text-[13px] {% if page.url == post.url %}text-[#111] font-bold{% else %}text-neutral-400{% endif %} no-underline flex flex-col gap-1.5">
                <span class="opacity-60">{{ loop.index | idx }}</span>
                <span>{{ post.data.title | truncate(25) }}</span>
            </a>
            {% endfor %}
        </div>
    </aside>

    <main class="flex-1 flex flex-col overflow-hidden">
        <header class="flex w-full border-b border-[#111] h-14 items-center justify-between px-5 shrink-0 font-mono text-[10px] text-neutral-400">
            <a href="/" class="mobile-back hidden items-center gap-1 text-[#111] no-underline font-bold uppercase hover:opacity-60">
                ← BACK
            </a>
            <div class="hidden md:block">[{{ category or "POST" }}]</div>
            <div id="clock">00:00:00</div>
        </header>

        <div class="flex-1 overflow-y-auto p-6 md:p-10">
            <div class="w-full max-w-[600px]">
                <h1 class="text-3xl font-bold tracking-tight mb-8 text-[#111] leading-tight">{{ title }}</h1>
                <div class="article-body">{{ content | safe }}</div>
            </div>
        </div>
    </main>
</div>

<script>
    function updateClock() {
        document.getElementById('clock').textContent = new Date().toTimeString().split(' ')[0];
    }
    setInterval(updateClock, 1000); updateClock();
</script>
</body>
</html>
