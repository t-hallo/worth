<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }} // WORTH.EE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet">
    <style>
        .font-syne { font-family: 'Syne', sans-serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* 强制网格容器 */
        #outerWrap { height: calc(100vh - 3rem); }
        @media (max-width: 768px) { #outerWrap { height: 100vh; } }
        
        /* 文章排版系统 */
        .article-body { font-size: 1rem; line-height: 1.8; color: #111111; font-weight: 500; }
        .article-body p { margin-bottom: 1.5rem; }
        .article-body h2 { font-family: 'Syne', sans-serif; font-size: 1.5rem; margin: 2.5rem 0 1rem; }
        .article-body a { text-decoration: underline; text-underline-offset: 4px; }
        .article-body a:hover { color: #000; }
        
        /* 列表逻辑 */
        .article-body ul li { margin-bottom: 0.5rem; }
    </style>
</head>
<body class="p-2 md:p-6 selection:bg-[#111] selection:text-white bg-white overflow-hidden">

<div id="outerWrap" class="border border-[#111] w-full flex flex-col bg-white overflow-hidden">

    <div class="flex w-full border-b border-[#111] h-16 items-center justify-between px-6 shrink-0 z-10 bg-white">
        <div class="font-syne text-xl tracking-tighter flex items-center gap-3">
            <a href="/" class="font-black no-underline text-[#111]">WORTH.EE</a>
            <span class="text-[9px] bg-[#111] text-white px-2 py-0.5 font-mono">// ARCHIVE</span>
        </div>
        <div class="font-mono text-xs tracking-widest text-neutral-800" id="clock">00:00:00</div>
    </div>

    <div class="flex-1 overflow-y-auto no-scrollbar bg-white">
        <div class="max-w-[720px] mx-auto px-6 py-16 md:py-24">
            
            <div class="text-[10px] font-mono text-neutral-400 tracking-widest mb-8 flex gap-4">
                <span>[{{ category or "02 // ARCHITECTURE" }}]</span>
                <span>{{ date | date("yyyy.MM.dd") }}</span>
            </div>

            <h1 class="font-syne text-4xl md:text-6xl font-black tracking-tight leading-[0.95] mb-12">
                {{ title }}
            </h1>

            <div class="article-body">
                {{ content | safe }}
            </div>

            <div class="mt-20 pt-8 border-t border-[#111] grid grid-cols-2 gap-8">
                {% if prevPost %}
                <a href="{{ prevPost.url }}" class="block group no-underline text-[#111]">
                    <div class="text-[10px] font-mono text-neutral-400 mb-2">← PREV</div>
                    <div class="text-sm font-bold group-hover:underline">{{ prevPost.data.title }}</div>
                </a>
                {% endif %}
                {% if nextPost %}
                <a href="{{ nextPost.url }}" class="block group no-underline text-[#111] text-right">
                    <div class="text-[10px] font-mono text-neutral-400 mb-2">NEXT →</div>
                    <div class="text-sm font-bold group-hover:underline">{{ nextPost.data.title }}</div>
                </a>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="flex w-full border-t border-[#111] h-12 items-center justify-between px-6 text-[10px] font-mono text-neutral-400 bg-white shrink-0">
        <div>© 2026 WORTH.EE LIGHT PROTOCOL.</div>
        <a href="/" class="text-[#111] hover:underline no-underline">[▲ INDEX]</a>
    </div>

</div>

<script>
    function updateClock() {
        document.getElementById('clock').textContent = new Date().toTimeString().split(' ')[0];
    }
    setInterval(updateClock, 1000); updateClock();
</script>
</body>
</html>
