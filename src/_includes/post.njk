<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }} // WORTH.EE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet">
    <style>
        .font-syne { font-family: 'Syne', sans-serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* 整体居中悬浮档案框 */
        body { background-color: #f7f7f7; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        #outerWrap {
            width: 90%; max-width: 900px; height: 85vh;
            border: 1px solid #111; display: flex; flex-direction: row;
            background: white; overflow: hidden;
        }

        /* 移动端适配：取消分栏 */
        @media (max-width: 768px) {
            body { padding: 0; }
            #outerWrap { width: 100%; height: 100vh; border: none; flex-direction: column; }
            #sidebar { display: none; }
        }

        .article-body { font-size: 0.95rem; line-height: 1.8; color: #111111; }
        .article-body p { margin-bottom: 1.5rem; }
        .article-body a { text-decoration: underline; text-underline-offset: 4px; }
        .article-body a:hover { color: #d00; }
    </style>
</head>
<body class="selection:bg-[#111] selection:text-white overflow-hidden">

<div id="outerWrap">
    <aside id="sidebar" class="w-[220px] border-r border-[#111] p-6 flex flex-col shrink-0 bg-white">
        <div class="font-syne text-lg font-black mb-8">WORTH.EE</div>
        <div class="text-[9px] font-mono text-neutral-400 mb-6 tracking-widest">[INDEX]</div>
        <div class="flex flex-col gap-3 font-mono text-[10px]">
            {% for post in collections.posts %}
            <a href="{{ post.url }}" class="{% if page.url == post.url %}text-[#111] font-bold{% else %}text-neutral-400 hover:text-[#111]{% endif %} no-underline">
                {{ loop.index | idx }} // {{ post.data.title | truncate(18) }}
            </a>
            {% endfor %}
        </div>
        <div class="mt-auto text-[9px] font-mono text-neutral-400 pt-6 border-t border-[#111]">
            STATUS: PERSISTENT
        </div>
    </aside>

    <main class="flex-1 flex flex-col overflow-hidden bg-white">
        <header class="flex w-full border-b border-[#111] h-14 items-center justify-between px-6 shrink-0">
            <div class="text-[9px] font-mono text-neutral-400">[{{ category or "POST" }}]</div>
            <div class="font-mono text-[10px] text-neutral-400" id="clock">00:00:00</div>
        </header>

        <div class="flex-1 overflow-y-auto no-scrollbar p-10">
            <div class="max-w-[500px]">
                <h1 class="font-syne text-4xl font-black tracking-tight leading-[0.95] mb-10 text-[#111]">
                    {{ title }}
                </h1>
                <div class="article-body">
                    {{ content | safe }}
                </div>
            </div>
        </div>

        <footer class="h-10 border-t border-[#111] flex items-center px-6 text-[9px] font-mono text-neutral-400 justify-between">
            <div>{{ date | date("yyyy.MM.dd") }}</div>
            <a href="/" class="text-[#111] hover:underline no-underline">[▲ RETURN TO INDEX]</a>
        </footer>
    </main>
</div>

<script>
    function updateClock() {
        document.getElementById('clock').textContent = new Date().toTimeString().split(' ')[0];
    }
    setInterval(updateClock, 1000); updateClock();
</script>
</body>
</html>
