<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }} // WORTH.EE</title>
    <link rel="stylesheet" href="/css/dist.css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Space Grotesk', "PingFang SC", sans-serif;
            background-color: #f7f7f7;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            cursor: crosshair;
        }
        .font-syne { font-family: 'Syne', sans-serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        #outerWrap {
            width: 95%;
            max-width: 850px;
            height: 90vh;
            border: 1px solid #111;
            display: flex;
            flex-direction: row;
            background: white;
            overflow: hidden;
        }

        /* 文章正文 */
        .article-body { font-size: 0.9rem; line-height: 2; color: #222; }
        .article-body p { margin-bottom: 1rem; }
        .article-body h2 {
            font-size: 0.65rem;
            font-family: 'Space Grotesk', monospace;
            letter-spacing: 0.16em;
            color: #999;
            margin-top: 2.5rem;
            margin-bottom: 0.6rem;
            font-weight: 500;
            text-transform: uppercase;
        }
        .article-body h3 { font-size: 0.88rem; font-weight: 700; margin-top: 1.8rem; margin-bottom: 0.4rem; }
        .article-body ul, .article-body ol { padding: 0; margin-bottom: 1rem; list-style: none; }
        .article-body ul li, .article-body ol li { padding-left: 1.25rem; position: relative; margin-bottom: 0.35rem; }
        .article-body ul li::before { content: "—"; position: absolute; left: 0; color: #bbb; }
        .article-body ol { counter-reset: item; }
        .article-body ol li::before { content: counter(item) "."; counter-increment: item; position: absolute; left: 0; color: #bbb; font-size: 0.75rem; font-family: monospace; }
        .article-body a { border-bottom: 1px solid #ddd; text-decoration: none; color: inherit; }
        .article-body a:hover { border-color: #111; }
        .article-body blockquote { border-left: 1px solid #111; margin: 1.5rem 0; padding: 0.4rem 0 0.4rem 1.25rem; color: #555; }
        .article-body code { font-family: monospace; font-size: 0.82rem; background: #f4f4f4; padding: 1px 5px; }
        .article-body pre { background: #f4f4f4; padding: 1rem 1.25rem; margin-bottom: 1rem; overflow-x: auto; font-size: 0.8rem; line-height: 1.6; }
        .article-body pre code { background: none; padding: 0; }
        .article-body hr { border: none; border-top: 1px dotted #ddd; margin: 2rem 0; }

        /* 侧边栏导航项 */
        .nav-item { display: block; width: 100%; transition: color 0.2s; }

        /* 手机适配 */
        @media (max-width: 768px) {
            body { padding: 0; align-items: flex-start; cursor: auto; }
            #outerWrap { width: 100%; height: 100vh; border: none; flex-direction: column; }
            #sidebar { display: none; }
            .article-body { font-size: 0.97rem; }
        }
    </style>
</head>
<body class="selection:bg-[#111] selection:text-white">

<div id="outerWrap">

    <!-- 左侧目录栏 -->
    <aside id="sidebar" class="w-[200px] border-r border-[#111] p-6 flex flex-col shrink-0 bg-[#fafafa]">
        <a href="/" class="font-syne text-[11px] font-black tracking-[0.2em] mb-8 text-[#111] no-underline block">
            WORTH.EE
        </a>
        <div class="text-[9px] font-mono text-neutral-400 mb-5 tracking-[0.15em] border-b border-[#111] pb-2">
            [INDEX_FILE]
        </div>
        <div class="flex flex-col gap-4 font-mono flex-1 overflow-y-auto no-scrollbar">
            {% for post in collections.posts %}
            <a href="{{ post.url }}"
               class="nav-item text-[10px] leading-tight no-underline flex flex-col gap-0.5
               {% if page.url == post.url %}text-[#111] font-bold{% else %}text-neutral-400 hover:text-[#111]{% endif %}">
                <span class="opacity-50">{{ loop.index | idx }}</span>
                <span>{{ post.data.title | truncate(22) }}</span>
            </a>
            {% endfor %}
        </div>
        <!-- 底部联系 -->
        <div class="border-t border-neutral-200 pt-4 flex flex-col gap-2 font-mono text-[9px] text-neutral-400 shrink-0 mt-4">
            <a href="mailto:{{ site.email }}" class="hover:text-[#111] transition-colors no-underline">→ MAIL</a>
            <a href="/feed.xml" class="hover:text-[#111] transition-colors no-underline">→ RSS</a>
        </div>
    </aside>

    <!-- 主内容区 -->
    <main class="flex-1 flex flex-col overflow-hidden">

        <!-- 顶部 meta 条 -->
        <header class="flex w-full border-b border-[#111] h-10 items-center justify-between px-5 shrink-0 text-[9px] font-mono text-neutral-400 bg-white">
            <div>[{{ category or "POST" }}] {{ date | date("yyyy.MM.dd") }}</div>
            <div class="flex items-center gap-4">
                <div id="clock">00:00:00</div>
                <a href="/" class="text-neutral-400 hover:text-[#111] transition-colors no-underline hidden md:block">[← BACK]</a>
            </div>
        </header>

        <!-- 正文滚动区 -->
        <div class="flex-1 overflow-y-auto no-scrollbar px-8 md:px-12 py-8">

            <!-- 标题 -->
            <h1 class="font-syne text-2xl md:text-3xl font-black tracking-tight leading-tight mb-2 text-[#111]">
                {{ title }}
            </h1>

            <!-- 分隔线 -->
            <div class="border-t border-[#111] mt-6 mb-8"></div>

            <!-- 正文 -->
            <div class="article-body">
                {{ content | safe }}
            </div>

            <!-- 上一篇 / 下一篇 -->
            <div class="border-t border-dotted border-neutral-200 mt-12 pt-6 grid grid-cols-2 gap-6 text-[9px] font-mono">
                <div>
                    {% if prevPost %}
                    <div class="text-neutral-400 mb-1.5 tracking-wider">← PREV</div>
                    <a href="{{ prevPost.url }}" class="text-neutral-600 hover:text-[#111] transition-colors no-underline text-[10px] font-bold leading-snug block">
                        {{ prevPost.data.title | truncate(36) }}
                    </a>
                    {% endif %}
                </div>
                <div class="text-right">
                    {% if nextPost %}
                    <div class="text-neutral-400 mb-1.5 tracking-wider">NEXT →</div>
                    <a href="{{ nextPost.url }}" class="text-neutral-600 hover:text-[#111] transition-colors no-underline text-[10px] font-bold leading-snug block">
                        {{ nextPost.data.title | truncate(36) }}
                    </a>
                    {% endif %}
                </div>
            </div>

        </div>

        <!-- 底部 footer -->
        <footer class="h-9 border-t border-[#111] flex items-center px-5 text-[9px] font-mono text-neutral-400 justify-between shrink-0 bg-white">
            <div>© 2026 WORTH.EE LIGHT PROTOCOL.</div>
            <a href="/" class="text-[#111] hover:underline no-underline tracking-widest">[▲ INDEX]</a>
        </footer>

    </main>
</div>

<script>
(function tick(){
    document.getElementById('clock').textContent = new Date().toTimeString().split(' ')[0];
    setTimeout(tick, 1000);
})();
</script>
</body>
</html>
