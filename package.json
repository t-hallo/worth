{
  "name": "worthee-site",
  "version": "1.0.0",
  "scripts": {
    "build": "tailwindcss -i ./src/css/global.css -o ./src/css/dist.css && eleventy",
    "start": "concurrently \"tailwindcss -i ./src/css/global.css -o ./src/css/dist.css --watch\" \"eleventy --serve --port=8080\"",
    "watch": "eleventy --watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "concurrently": "^9.0.0"
  }
}
